{
  "ApiLogging": {
    "DefaultMode": "RequestOnly",
    "MaxBodyLength": 4096,
    "Rules": [
      {
        "Name": "No log for swagger static",
        "Method": "*",
        "Path": "/swagger*",
        "Mode": "None"
      },
      {
        "Name": "No log for health",
        "Method": "GET",
        "Path": "/health",
        "Mode": "None"
      },
      {
        "Name": "Full log for login",
        "Method": "POST",
        "Path": "/api/auth/login",
        "Mode": "Full"
      },
      {
        "Name": "Full log for refresh token",
        "Method": "POST",
        "Path": "/api/auth/refresh-token",
        "Mode": "Full"
      },
      {
        "Name": "Request-only log for logout",
        "Method": "POST",
        "Path": "/api/auth/logout",
        "Mode": "RequestOnly"
      }
    ]
  }
}
